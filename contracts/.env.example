# Canonical env-var names (doc 00) — copy to .env and fill in.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_ONE_RPC_URL=https://arb1.arbitrum.io/rpc
# Etherscan API V2 — one key, multichain.
ETHERSCAN_API_KEY=PLACEHOLDER
# Dev deploys only; production deploys run from a hardware/KMS-backed key (doc 07).
DEPLOYER_PRIVATE_KEY=0xPLACEHOLDER

# --- Deploy.s.sol constructor args (PROPOSED names, module 07; all optional) ---
# Each defaults to the deployer address when unset. agent is IMMUTABLE in the
# contract — set AGENT_ADDRESS to the KMS agent address for the real One deploy
# (module 08), else the dev deploy bakes in the deployer and a KMS switch later
# means a redeploy (<$0.50).
#AGENT_ADDRESS=0x
#KEEPER_ADDRESS=0x
#RELAYER_ADDRESS=0x
# Canonical name reused from the doc-00 worker table; contract default is 60.
#DEMO_CHALLENGE_WINDOW_SECS=60
