{
  "name": "worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -b",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "smoke:kms": "tsx --env-file-if-exists=.env scripts/smoke-kms.ts",
    "rehearse:staging": "tsx --env-file-if-exists=.env scripts/rehearse-staging-plan.ts",
    "rehearse:rogue": "tsx --env-file-if-exists=.env scripts/rehearse-rogue.ts",
    "rehearse:failure": "tsx --env-file-if-exists=.env scripts/rehearse-failure.ts",
    "rehearse:g4": "tsx --env-file-if-exists=.env scripts/rehearse-g4.ts",
    "verify:nodup": "tsx --env-file-if-exists=.env scripts/verify-no-duplicates.ts",
    "verify:kill": "tsx --env-file-if-exists=.env scripts/verify-kill.ts",
    "verify:estate": "tsx --env-file-if-exists=.env scripts/verify-estate.ts",
    "verify:revoke-all": "tsx --env-file-if-exists=.env scripts/verify-revoke-all.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3",
    "@retenix/db": "workspace:*",
    "@retenix/registry": "workspace:*",
    "@retenix/shared": "workspace:*",
    "@retenix/ua": "workspace:*",
    "@sentry/node": "^10",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6",
    "node-cron": "^4",
    "p-queue": "^9.3.1",
    "pg-boss": "^12",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4"
  }
}
