INTERNAL_API_TOKEN=dev-internal-token-change-me
DEMO_INACTIVITY_SECS=120
DEMO_CHALLENGE_WINDOW_SECS=60
# "1" enables demo-only affordances (POST /internal/demo/rogue). Default off.
DEMO_MODE=0
# PROPOSED (doc 12): snapshot-cron display-marks source — mirrors the web's
# NEXT_PUBLIC_PORTFOLIO_LIVE marks half; set the two together.
PORTFOLIO_MARKS=jupiter
# Internal HTTP surface (execute-now / rogue / healthz); Railway injects PORT.
PORT=8080

# --- module 14 (estate keeper/heartbeat) ---
APP_BASE_URL=http://localhost:3000
# PROPOSED provider (doc 17 records it): absent -> claim links are logged, not emailed.
#RESEND_API_KEY=re_PLACEHOLDER
#EMAIL_FROM=Retenix <legacy@retenix.example>
