# keys live in AWS KMS, never env vars.
# AGENT_EOA_PRIVATE_KEY=0xPLACEHOLDER
RPC_URL_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/PLACEHOLDER
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/PLACEHOLDER
RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/PLACEHOLDER
RPC_URL_BSC=https://bnb-mainnet.g.alchemy.com/v2/PLACEHOLDER
RPC_URL_XLAYER=https://rpc.xlayer.tech
RPC_URL_SOLANA=https://solana-mainnet.g.alchemy.com/v2/PLACEHOLDER
