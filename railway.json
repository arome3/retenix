{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter worker build",
    "watchPatterns": [
      "apps/worker/**",
      "packages/**",
      "patches/**",
      "scripts/check-worker-runtime-deps.mjs",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "pnpm db:push",
    "startCommand": "pnpm --filter worker start",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "sleepApplication": false,
    "drainingSeconds": 75,
    "overlapSeconds": 0
  }
}
