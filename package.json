{
  "name": "retenix",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n web,worker -c blue,magenta \"pnpm --filter web dev\" \"pnpm --filter worker dev\"",
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "tsc -b && tsc -p apps/web --noEmit",
    "lint": "eslint .",
    "db:push": "pnpm --filter @retenix/db db:push",
    "db:generate": "pnpm --filter @retenix/db db:generate",
    "e2e": "playwright test --config e2e/playwright.config.ts --pass-with-no-tests",
    "check:pins": "node scripts/check-pins.mjs",
    "contrast": "node --experimental-strip-types scripts/contrast.ts",
    "copy-canon": "node scripts/copy-canon.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1",
    "concurrently": "^10",
    "dotenv": "^17",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jose": "^6.2.3",
    "pg": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4"
  }
}
